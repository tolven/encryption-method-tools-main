   "source": [
    "def multiinv(x,mod):\n",
    "    y = 0\n",
    "    while (x * y % mod != 1):\n",
    "        y += 1\n",
    "        print(x, \"*\", y, \" mod \", mod, \" = \", x * y % mod)\n",
    "    print(\"Multiplikative Inverse: \", y)"
   ]
  },
